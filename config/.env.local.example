# ===== OpenMemory =====
# OpenMemory 服务地址（默认同机运行，端口 8081）
OM_BASE_URL=http://127.0.0.1:8081
# API 密钥（如 OpenMemory 需要认证，请填写；否则可留空）
OM_API_KEY=
# 数据来源标识（用于标记存入 OpenMemory 的数据来源）
OM_SOURCE=Jarvis
# 请求超时时间（毫秒）
OM_TIMEOUT_MS=8000
# 默认存储类型
OM_STORE_DEFAULT_TYPE=note
# 搜索返回结果数量限制
OM_SEARCH_LIMIT=5
# 排除的类型（逗号分隔，如：transient,temp）
OM_EXCLUDE_TYPES=transient
# 显式覆盖端点（可留空；若不填，后续客户端将使用自适配候选）
# 例如：/api/v1/notes 或 /notes
OM_ENDPOINT_STORE=
OM_ENDPOINT_SEARCH=

# ===== LLM (DeepSeek) =====
# LLM 提供商（当前仅支持 deepseek）
LLM_PROVIDER=deepseek
# DeepSeek API 密钥（必须填写，否则无法调用 LLM）
DEEPSEEK_API_KEY=
# DeepSeek API 基础地址（可选，默认使用官方地址）
DEEPSEEK_BASE_URL=
