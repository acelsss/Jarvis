# ===== OpenMemory =====
OM_BASE_URL=http://127.0.0.1:8081
OM_API_KEY=
OM_SOURCE=Jarvis
OM_TIMEOUT_MS=8000
OM_STORE_DEFAULT_TYPE=note
OM_SEARCH_LIMIT=5
OM_EXCLUDE_TYPES=transient
# 显式覆盖端点（可留空；若不填，后续客户端将使用自适配候选）
OM_ENDPOINT_STORE=
OM_ENDPOINT_SEARCH=

# ===== LLM (DeepSeek) =====
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=

